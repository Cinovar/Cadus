# Banco de dados Neon (PostgreSQL serverless)
# Obtenha em: https://console.neon.tech
NEON_DATABASE_URL_DEV=postgresql://user:password@host/dbname?sslmode=require

# Porta do serviço historico (padrão: 3002)
# register roda em 3000, auth em 3001
PORT=3002

# Ambiente de execução
NODE_ENV=development