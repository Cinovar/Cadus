# Banco de dados Neon (PostgreSQL serverless) — pool de conexões
# Obtenha em: https://console.neon.tech
DATABASE_URL_POOLED=postgresql://user:password@host/dbname?sslmode=require

# Chave secreta para assinar os JWTs — use uma string longa e aleatória em produção
JWT_SECRET=troque-por-uma-chave-secreta-forte

# URL do serviço register — usado pelo auth para buscar usuário por CPF no login
REGISTER_SERVICE_URL=http://localhost:3000

# Porta do serviço auth (padrão: 3001)
# register roda em 3000, historico em 3002
PORT=3001

# Ambiente de execução
NODE_ENV=development